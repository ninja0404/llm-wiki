{
  "name": "llm-wiki",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @llm-wiki/api dev & pnpm --filter @llm-wiki/api worker & pnpm --filter @llm-wiki/web dev & wait",
    "build": "pnpm -r build",
    "dev:api": "pnpm --filter @llm-wiki/api dev",
    "dev:web": "pnpm --filter @llm-wiki/web dev",
    "dev:worker": "pnpm --filter @llm-wiki/api worker",
    "db:generate": "pnpm --filter @llm-wiki/api db:generate",
    "db:migrate": "pnpm --filter @llm-wiki/api db:migrate",
    "db:push": "pnpm --filter @llm-wiki/api db:push",
    "db:studio": "pnpm --filter @llm-wiki/api db:studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "lint": "pnpm -r lint"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "msgpackr-extract"]
  }
}
