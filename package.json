{
  "name": "llm-wiki",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --filter @llm-wiki/api dev & bun run --filter @llm-wiki/api worker & bun run --filter @llm-wiki/web dev & wait",
    "build": "bun run --filter '*' build",
    "dev:api": "bun run --filter @llm-wiki/api dev",
    "dev:web": "bun run --filter @llm-wiki/web dev",
    "dev:worker": "bun run --filter @llm-wiki/api worker",
    "db:generate": "bun run --filter @llm-wiki/api db:generate",
    "db:migrate": "bun run --filter @llm-wiki/api db:migrate",
    "db:push": "bun run --filter @llm-wiki/api db:push",
    "db:studio": "bun run --filter @llm-wiki/api db:studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "lint": "bun run --filter '*' lint"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "workspaces": [
    "api",
    "web",
    "packages/*"
  ]
}
