# App
APP_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
MCP_URL=http://localhost:8080/mcp
CONVERTER_URL=http://localhost:8090

# PostgreSQL
POSTGRES_USER=llmwiki
POSTGRES_PASSWORD=llmwiki
POSTGRES_DB=llmwiki
POSTGRES_PORT=5432
DATABASE_URL=postgresql://llmwiki:llmwiki@localhost:5432/llmwiki

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# MinIO / S3
MINIO_ENDPOINT=localhost:9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=llmwiki
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Security
JWT_SECRET=change-me-with-openssl-rand-base64-32
AGENT_TOKEN_SECRET=change-me-with-openssl-rand-base64-32

# LLM Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4.1-mini
DEFAULT_EMBEDDING_PROVIDER=openai
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small

# Worker
WORKER_POLL_INTERVAL_MS=1500
EMBEDDING_DIMENSIONS=1024
