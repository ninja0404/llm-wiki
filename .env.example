# ── PostgreSQL ──
PG_USER=llmwiki
PG_PASSWORD=llmwiki
PG_DB=llmwiki
PG_PORT=5432
PGBOUNCER_PORT=6432
DATABASE_URL=postgresql://llmwiki:llmwiki@localhost:5432/llmwiki

# ── Redis ──
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# ── MinIO (S3-compatible) ──
