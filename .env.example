# App
APP_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
MCP_URL=http://localhost:8080/mcp
CONVERTER_URL=http://localhost:8090

# PostgreSQL
POSTGRES_USER=llmwiki
POSTGRES_PASSWORD=llmwiki
POSTGRES_DB=llmwiki
POSTGRES_PORT=5432
DATABASE_URL=postgresql://llmwiki:llmwiki@localhost:5432/llmwiki

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# MinIO / S3
MINIO_ENDPOINT=localhost:9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=llmwiki
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Internal service auth
INTERNAL_SERVICE_TOKEN=REPLACE_WITH_openssl_rand_base64_48_MINIMUM_32_CHARS

# Envelope encryption master keys.
# Generate a 32-byte key with:
# python3 - <<'PY'
# import base64, secrets
# print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode().rstrip('='))
# PY
ACTIVE_KEY_VERSION=v1
KEYRING_JSON={"v1":"REPLACE_WITH_BASE64URL_32_BYTE_KEY"}

# Worker
WORKER_POLL_INTERVAL_MS=1500
EMBEDDING_DIMENSIONS=1024

# NOTE: Provider/model/base_url/api_key/search_rules/compiler_rules are configured
# per-workspace via workspace_settings only.
