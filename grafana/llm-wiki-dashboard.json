{
  "dashboard": {
    "title": "LLM Wiki Operations",
    "uid": "llm-wiki-ops",
    "panels": [
      {
        "title": "HTTP Request Rate",
        "type": "timeseries",
        "targets": [{ "expr": "rate(http_requests_total[5m])", "legendFormat": "{{method}} {{route}}" }],
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
      },
      {
        "title": "HTTP Latency P95",
        "type": "timeseries",
        "targets": [{ "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))", "legendFormat": "P95" }],
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
      },
      {
        "title": "LLM Invocation Duration",
        "type": "timeseries",
        "targets": [{ "expr": "histogram_quantile(0.95, rate(llm_invocation_duration_seconds_bucket[5m]))", "legendFormat": "{{provider}} {{step}}" }],
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
      },
      {
        "title": "LLM Tokens Used",
        "type": "stat",
        "targets": [{ "expr": "sum(increase(llm_tokens_used_total[24h]))", "legendFormat": "24h tokens" }],
        "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 }
      },
      {
        "title": "Active WebSockets",
        "type": "gauge",
        "targets": [{ "expr": "active_websocket_connections", "legendFormat": "connections" }],
        "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 }
      },
      {
        "title": "Ingest Queue Depth",
        "type": "timeseries",
        "targets": [{ "expr": "ingest_queue_depth", "legendFormat": "queue depth" }],
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 }
      },
      {
        "title": "Node.js Memory",
        "type": "timeseries",
        "targets": [{ "expr": "process_resident_memory_bytes", "legendFormat": "RSS" }],
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 }
      }
    ],
    "time": { "from": "now-6h", "to": "now" },
    "refresh": "30s"
  }
}
